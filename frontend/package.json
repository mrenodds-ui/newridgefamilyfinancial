{
  "name": "newridge-financial-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "build:v2": "tsc -b && vite build --mode v2",
    "generate:contracts": "..\\.venv\\Scripts\\python.exe ..\\scripts\\export_openapi.py src/api/generated/backend-openapi.json && openapi-typescript src/api/generated/backend-openapi.json -o src/api/generated/backend-openapi.ts",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "format": "biome format --write src",
    "lint": "biome lint src vite.config.ts vitest.config.ts",
    "check": "biome check src vite.config.ts vitest.config.ts",
    "check:ci": "biome ci src vite.config.ts vitest.config.ts",
    "build:check": "npm run build && node scripts/check-bundle-size.mjs",
    "lighthouse:local": "lhci autorun",
    "smoke:playwright": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:security": "vitest run src/__tests__/securityPolicies.test.ts src/__tests__/sanitizeHtml.test.ts",
    "test:a11y": "vitest run src/__tests__/a11y.test.tsx",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@types/react-router-dom": "^5.3.3",
    "classnames": "^2.5.1",
    "comlink": "^4.4.2",
    "dexie": "^4.4.4",
    "dompurify": "^3.4.11",
    "idb-keyval": "^6.2.6",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.80.0",
    "react-resizable": "^4.0.2",
    "react-router-dom": "^7.18.1",
    "react-window": "^2.2.7",
    "recharts": "^3.9.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@chromatic-com/storybook": "^5.2.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@storybook/tanstack-react": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/browser": "^2.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "axe-core": "^4.11.4",
    "eslint-plugin-storybook": "^10.4.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
